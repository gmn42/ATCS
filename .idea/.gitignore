# Ignore everything in .idea, then explicitly keep the shared project files
# that let another developer open, sync, and build the repo without
# regenerating IDE metadata.
*
# Keep this ignore policy file in git.
!.gitignore
# Keep packaged artifact definitions.
!artifacts/
# Keep shared code style settings.
!codeStyles/
# Keep compiler bytecode target settings.
!compiler.xml
# Keep Gradle import/sync settings.
!gradle.xml
# Keep project JDK/language level settings.
!misc.xml
# Keep the project module list.
!modules.xml
# Keep per-module IDEA metadata.
!modules/
# Keep module source/content mappings.
!modules/*.iml
# Keep the project display name.
!.name
# Keep shared run configuration settings.
!runConfigurations.xml
!runConfigurations/
!runConfigurations/*.xml
# Keep Git/VCS mapping settings.
!vcs.xml